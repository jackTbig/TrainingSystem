# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# AI 配置（必填，用于文档解析/课程生成/题目生成）
AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=your_qwen_api_key_here
AI_MODEL_NAME=qwen-plus

# 数据库（默认值已可用，Docker 启动后无需修改）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/training_db

# Redis / RabbitMQ（默认值）
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# JWT（生产环境务必修改）
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120
